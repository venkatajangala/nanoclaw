# --- Core Configuration ---
# Set to 'true' if the assistant uses a dedicated phone number
ASSISTANT_HAS_OWN_NUMBER=

# --- Ollama Local Integration ---
# Your local Ollama API endpoint (Standard is http://localhost:11434/v1)
ANTHROPIC_BASE_URL=http://localhost:11434/v1
# Ollama doesn't require a real key, but the SDK needs a string to function
ANTHROPIC_API_KEY=ollama
